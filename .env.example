# ── wxrk_voice configuration ─────────────────────────────────────────────────
# Copy to `.env` and fill in. Every provider is swappable by changing ONE var.
#   cp .env.example .env

# --- service ---
SERVICE_API_KEY=change-me-shared-bearer   # backend sends this as `Authorization: Bearer ...`
REQUIRE_AUTH=false                         # set true to enforce the bearer on every call
PORT=8080

# --- the provider seam (this is the whole point) ───────────────────────────────
# Switch any of these and nothing else changes. Defaults below are offline stubs
# so the service boots and `pytest` runs with no keys.
LLM_PROVIDER=stub        # stub (offline)  ->  gemini (hosted default)
STT_PROVIDER=stub        # stub (offline)  ->  deepgram (Nova-3)
TTS_PROVIDER=stub        # stub (offline)  ->  deepgram (Aura)

# Recommended production defaults (uncomment to go live):
# LLM_PROVIDER=gemini
# STT_PROVIDER=deepgram
# TTS_PROVIDER=deepgram

# --- LLM: hosted (Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- LLM: local swap target (Ollama, OpenAI-compatible API) ---
# Used by the live worker when LLM_PROVIDER is not "gemini".
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# --- LLM: multi-provider catalog (operation_files/MODELS.md) ───────────────────
# Drives GET /llm/options and the test-page model pickers. A provider only
# appears (and is selectable) when its key below is non-empty. With LLM_PROVIDER
# above left on stub/gemini, the chosen model still governs the cost readout;
# set LLM_PROVIDER=catalog to actually route each run to the chosen provider.
OPENAI_API_KEY=
XAI_API_KEY=
ANTHROPIC_API_KEY=          # add to enable Anthropic in the dropdowns
# Defaults used when a /sessions or /simulate call omits convo/extract:
#   role -> provider, then provider -> model (see MODELS.md "Env scheme")
CONVO_PROVIDER=xai          # openai | xai | anthropic
EXTRACT_PROVIDER=openai
# OPENAI_MODEL=gpt-5.4-mini   # explicit per-provider override (else *_MODEL_DEFAULT)
# XAI_MODEL=grok-4.3
# ANTHROPIC_MODEL=claude-haiku-4-5
# CONVO_MODEL=                # role override, wins over provider default
# EXTRACT_MODEL=gpt-5.4-mini

# --- STT / TTS: hosted (Deepgram) ---
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-asteria-en
# Local swap targets (documented): STT -> faster-whisper, TTS -> Piper.

# --- LiveKit (live audio transport; only needed for the mic path) ---
LIVEKIT_URL=                 # wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
